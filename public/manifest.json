{
  "manifest_version": 3,
  "name": "PageWhisperer",
  "version": "1.0.0",
  "description": "Read page content and summarize it with cloud or local LLMs",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "PageWhisperer"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ]
}